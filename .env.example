# Vercel / Vite frontend variables
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SITE_URL=https://www.smarttravelhacks.com

# Optional: the app automatically uses ${VITE_SUPABASE_URL}/functions/v1/server
# VITE_API_BASE=https://YOUR_PROJECT_REF.supabase.co/functions/v1/server

# Supabase Edge Function secrets; set in Supabase, not Vercel
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
ALLOWED_ORIGINS=https://www.smarttravelhacks.com
ADMIN_EMAILS=admin@example.com
NODE_ENV=production
ENVIRONMENT=production

# Optional production monitoring and bot protection
OPENAI_API_KEY=
SENTRY_DSN=
VITE_SENTRY_DSN=
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
